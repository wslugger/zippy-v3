datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================
// GLOBAL TAXONOMY (Singleton)
// ============================================================
model GlobalTaxonomy {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  slug            String   @unique @default("global_taxonomy_v1")
  collateralTypes String[]
  extraFields     Json?    // Stores any user-added categories not in the hardcoded columns
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("system_config")
}

// ============================================================
// SERVICE CATALOG
// Service → Service Options → Design Options hierarchy
// ============================================================
model Service {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  slug             String   @unique
  name             String
  shortDescription String
  description      String
  constraints      String[]
  assumptions      String[]
  serviceOptions   Json[]
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("services")
}

// ============================================================
// PACKAGE CATALOG (Selected in Module 1)
// ============================================================
model Package {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  slug             String   @unique
  name             String
  shortDescription String
  description      String
  includedServices Json[]   // Array of PackageInclusion (service, options, features + designation)
  collateral       Json[]   // Up to 4 collateral items { title, url, type }
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("packages")
}

// ============================================================
// PROJECT LEDGER (Central state document)
// ============================================================
model Project {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  customerName      String
  description       String?  @default("")
  status            String   @default("draft")
  moduleStates      Json     @default("{\"ingestion\":\"pending\",\"configuration\":\"locked\",\"bomGeneration\":\"locked\",\"hldGeneration\":\"locked\"}")

  // Module 1 output
  selectedPackageId String?  @db.ObjectId
  packageSlug       String?
  packageName       String?
  packageReasoning  String?
  packageCollateral Json[]

  // AI recommendation result (Module 1 assist)
  aiRecommendation  Json?    // { packageId, confidence, reasoning }

  // Module 2 output (stub)
  designConfiguration Json?

  // Module 3 output (stub)
  bomSnapshot       Json[]

  // Sites (populated later)
  sites             Json[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("projects")
}

// ============================================================
// AI PROMPT CATALOG
// Editable prompts per SA workflow step
// ============================================================
model AIPrompt {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  slug               String   @unique          // e.g. "package_selection"
  displayName        String                    // "Package Selection"
  model              String   @default("gemini-3-flash-preview")
  temperature        Float    @default(0.1)
  systemInstruction  String
  userPromptTemplate String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("ai_prompts")
}

// ============================================================
// CUSTOMER REQUIREMENTS
// Persisted extracted text from uploads or chat (for future phases)
// ============================================================
model CustomerRequirement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId String   @db.ObjectId
  source    String                    // "upload" | "chat"
  fileName  String?                   // original filename if uploaded
  rawText   String                    // extracted text content
  createdAt DateTime @default(now())

  @@map("customer_requirements")
}

// ============================================================
// FEATURE CATALOG
// Stand-alone features referenced by services
// ============================================================
model Feature {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  service     String
  status      String   @default("available")
  description String?
  caveats     String[]
  assumptions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("features")
}

